PORT=3001
# Development cross-origin client. Production uses the same origin by default.
CLIENT_ORIGIN=http://localhost:5173
# Optional in development and tests. Do not set for a single-origin Render deploy.
VITE_SERVER_URL=http://localhost:3001
QUEUE_BOT_DELAY_MS=60000
RECONNECT_GRACE_MS=10000
COUNTDOWN_MS=3000
ENABLE_TEST_API=false
